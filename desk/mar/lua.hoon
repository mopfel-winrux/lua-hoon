::  /mar/lua: Lua source text
::
::    a Lua source file, stored as a cord.  diffs delegate to %txt.
::
=,  format
=,  mimes:html
|_  pit=@t
++  grab
  |%
  ++  noun  @t
  ++  mime  |=([=mite =octs] `@t`q.octs)
  ++  txt   |=(t=wain (of-wain t))
  --
++  grow
  |%
  ++  noun  pit
  ++  txt   (to-wain pit)
  ++  mime  [/text/x-lua (as-octs pit)]
  --
++  grad  %txt
--
